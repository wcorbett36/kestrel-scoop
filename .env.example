# K-Compiler Execution Environment Variables
GEMINI_API_KEY=your_gemini_key_here

# Local MLX (punchcard-modelbase-mlx: make run-server) via LiteLLM
# OPENAI_API_BASE=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=sk-local

# Optional: transient LLM retries (connection/timeout only); backoff between attempts
# LLM_MAX_RETRIES=1
# LLM_RETRY_BACKOFF_SECONDS=0.5

# Optional: print full traceback on build failure
# K_COMPILER_DEBUG=1
